{
  "name": "recall-isnt-enough-artifacts",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Reproducibility artifacts for Recall Isn't Enough: Bounding Commitments in Personalized Language Systems.",
  "scripts": {
    "generate:fixtures": "node scripts/generate-cbea-lcv-expanded-fixtures.mjs --replicates=12 --out=data/fixtures/cbea-lcv.expanded360.synthetic.json",
    "generate:fixtures:shadow": "node scripts/generate-cbea-lcv-v6-shadow-fixtures.mjs --out=data/fixtures/cbea-lcv.v6-shadow360.synthetic.json --stats=data/fixtures/cbea-lcv.v6-shadow360.stats.json",
    "pilot:fixtures:shadow": "node scripts/build-shadow-pilot-fixtures.mjs --input=data/fixtures/cbea-lcv.v6-shadow360.synthetic.json --out=results/pilot_shadow/fixtures.json --manifest=results/pilot_shadow/fixture-selection.json",
    "summarize:metrics": "node scripts/summarize-automatic-metrics.mjs --input=data/results/real-pilot-results.csv --out=runs/automatic-metrics.csv",
    "summarize:bootstrap": "node scripts/bootstrap-headline-diffs.mjs --input=data/results/real-pilot-results.csv --out=runs/bootstrap-headline-diffs.csv",
    "summarize:horizon": "node scripts/summarize-horizon-stability.mjs --fixtures=data/fixtures/cbea-lcv.expanded360.synthetic.json --input=data/results/real-pilot-results.csv --out=runs/horizon-stability.csv",
    "summarize:long-history": "node scripts/summarize-long-history-payload.mjs --input=data/results/long-history-payload-results.csv --out=runs/long-history-payload-summary.csv",
    "summarize:judge": "node scripts/summarize-llm-fidelity-audit.mjs --labels=data/model_judge/combined-labels.csv --pairwise=data/model_judge/combined-pairwise.csv --out=runs/llm-judge-summary",
    "summarize:judge-bootstrap": "node scripts/bootstrap-judge-wins.mjs --pairwise=data/model_judge/combined-pairwise.csv --key=data/model_judge/annotation-key.csv --out=runs/judge-winner-bootstrap.csv",
    "summarize:selector-baselines": "node scripts/summarize-selector-baselines.mjs --fixtures=data/fixtures/cbea-lcv.expanded360.synthetic.json --out=runs/selector-baseline-mmr.csv",
    "summarize:boundary": "node scripts/summarize-boundary-diagnostics.mjs --out=runs/boundary-diagnostics-summary.json",
    "judge:sample": "node scripts/build-model-judge-sample.mjs --fixtures=data/fixtures/cbea-lcv.expanded360.synthetic.json --results=data/results/real-pilot-results.csv --out=data/model_judge/balanced-90 --cases-per-group=3",
    "make:task-shards": "node scripts/make-cbea-task-shards.mjs",
    "merge:result-shards": "node scripts/merge-result-shards.mjs",
    "rescore:results": "node scripts/rescore-cbea-results.mjs",
    "test:harness": "node --test scripts/check-clean-harness.test.mjs",
    "check:privacy": "node scripts/check-privacy-boundary.mjs",
    "check:table-cases": "node scripts/check-public-table-cases.mjs",
    "check:release": "node scripts/check-release-tables.mjs",
    "check": "npm run test:harness && npm run summarize:metrics && npm run summarize:bootstrap && npm run summarize:horizon && npm run summarize:long-history && npm run summarize:judge && npm run summarize:judge-bootstrap && npm run summarize:selector-baselines && npm run summarize:boundary && npm run check:release && npm run check:table-cases && npm run check:privacy"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
