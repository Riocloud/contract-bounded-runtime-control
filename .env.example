# OpenAI-compatible provider for matched offline generation.
PROVIDER_BASE_URL=https://api.example.com
PROVIDER_MODEL=provider-model-name
PROVIDER_API_KEY=replace-me
# Set to "none" for providers that do not support OpenAI JSON response_format.
PROVIDER_RESPONSE_FORMAT=json_object
# Optional provider-specific reasoning control, for example "none".
PROVIDER_REASONING=

# OpenAI-compatible provider for model-judge audits.
LLM_JUDGE_BASE_URL=https://api.example.com/v1
LLM_JUDGE_MODEL=judge-model-name
LLM_JUDGE_API_KEY=replace-me
