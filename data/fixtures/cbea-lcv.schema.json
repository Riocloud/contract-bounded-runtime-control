{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Synthetic CBEA/LCV Benchmark Fixture",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "fixture_id",
      "scenario_focus",
      "noisy_user_observations",
      "confirmed_hard_constraints",
      "mutable_state_facts",
      "required_dimensions",
      "required_detail_slots",
      "required_witnesses",
      "tail_witnesses",
      "consequence_debt",
      "runtime_repair_guards",
      "oracle_feasible_set_empty",
      "expected_repair_or_abstain",
      "expected_valid_commitment_fields",
      "failure_surface"
    ],
    "properties": {
      "fixture_id": { "type": "string", "minLength": 1 },
      "scenario_focus": {
        "type": "string",
        "enum": ["investment", "love_choice", "career", "relocation", "comprehensive"]
      },
      "noisy_user_observations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "confirmed_hard_constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "validator_covered_hard_constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "mutable_state_facts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "required_dimensions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "required_detail_slots": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "validator_covered_detail_slots": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "required_witnesses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "validator_covered_required_witnesses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "tail_witnesses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "validator_covered_tail_witnesses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "consequence_debt": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "validator_covered_consequence_debt": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "shadow_oracle": {
        "type": "object",
        "additionalProperties": false,
        "required": ["facts", "noise_density_score"],
        "properties": {
          "noise_density_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "facts": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "canonical",
                "aliases",
                "paraphrase_patterns",
                "type",
                "weight",
                "turn_due_by",
                "polarity",
                "embedded_in_turns"
              ],
              "properties": {
                "id": { "type": "string", "pattern": "^sh[0-9]+$" },
                "canonical": { "type": "string", "minLength": 1 },
                "aliases": {
                  "type": "array",
                  "minItems": 3,
                  "items": { "type": "string", "minLength": 1 }
                },
                "paraphrase_patterns": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "type": {
                  "type": "string",
                  "enum": ["constraint", "evidence", "detail", "consequence"]
                },
                "weight": { "type": "number", "exclusiveMinimum": 0 },
                "turn_due_by": { "type": "integer", "minimum": 0 },
                "polarity": {
                  "type": "string",
                  "enum": ["respect", "contradict_detection"]
                },
                "embedded_in_turns": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "integer", "minimum": 0 }
                }
              }
            }
          }
        }
      },
      "runtime_repair_guards": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["contract_conflict", "missing_evidence", "unsupported_commitment", "validator_failure"]
        }
      },
      "oracle_feasible_set_empty": { "type": "boolean" },
      "expected_repair_or_abstain": { "type": "boolean" },
      "expected_valid_commitment_fields": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "failure_surface": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "false_hardening",
            "hidden_exception",
            "witness_drop",
            "no_feasible_candidate",
            "consequence_debt",
            "over_personalization",
            "surface_mismatch"
          ]
        }
      },
      "h_star": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["predicate_id", "expr", "validator_covered"],
          "properties": {
            "predicate_id": { "type": "string", "minLength": 1 },
            "expr": { "type": "string", "minLength": 1 },
            "validator_covered": { "type": "boolean" }
          }
        }
      },
      "E_star": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["evidence_id", "validator_covered"],
          "properties": {
            "evidence_id": { "type": "string", "minLength": 1 },
            "validator_covered": { "type": "boolean" }
          }
        }
      },
      "F_star": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "turns": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["turn_index", "user", "system_action_oracle"],
          "properties": {
            "turn_index": { "type": "integer", "minimum": 0 },
            "user": { "type": "string", "minLength": 1 },
            "system_action_oracle": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
